# ============================================
# CV EVALUATION SYSTEM - ENVIRONMENT CONFIG
# ============================================
# All processing happens locally with Ollama.
# No data leaves your computer.

# ============================================
# LLM CONFIGURATION
# ============================================

USE_LOCAL_LLM=true
LOCAL_LLM_BACKEND=ollama

# Model selection (depends on your RAM):
#
# For 8GB RAM (recommended):
#   - qwen2.5:3b (best balance of quality/speed)
#   - phi3:mini (good for instructions)
#   - llama3.2:3b (good quality)
#   - gemma2:2b (lightest)
#
# For 16GB+ RAM:
#   - llama3.1:8b (recommended)
#   - mistral:7b
#   - qwen2.5:7b
#
LOCAL_LLM_MODEL=qwen2.5:3b

# ============================================
# OPTIONAL SETTINGS
# ============================================

# LLM_TEMPERATURE=0.1
# CACHE_ENABLED=true
