# ============================================
# LLM CONFIGURATION
# ============================================

# Choose between LOCAL LLM (private) or GROQ (cloud)
# Set to 'true' to use local LLM (100% private, no data leaves your computer)
# Set to 'false' to use Groq API (requires internet and API key)
USE_LOCAL_LLM=true

# ============================================
# GROQ API CONFIGURATION (Only if USE_LOCAL_LLM=false)
# ============================================
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# LOCAL LLM CONFIGURATION (Only if USE_LOCAL_LLM=true)
# ============================================

# Backend options: 'ollama', 'lmstudio', or 'llamacpp'
LOCAL_LLM_BACKEND=ollama

# Model name (depends on backend):
# Para 8GB RAM + CPU usar modelos ligeros:
# - qwen2.5:3b (RECOMENDADO - buen balance calidad/velocidad)
# - phi3:mini (excelente para instrucciones)
# - llama3.2:3b (buena calidad)
# - gemma2:2b (más ligero)
# Para 16GB+ RAM: llama3.1:8b, mistral:7b, qwen2.5:7b
LOCAL_LLM_MODEL=qwen2.5:3b

# Model file path (only for llamacpp backend)
# Example: /Users/yourname/models/llama-2-7b-chat.Q4_K_M.gguf
# LOCAL_LLM_MODEL_PATH=/path/to/your/model.gguf

# ============================================
# OPTIONAL LLM SETTINGS (applies to both local and cloud)
# ============================================
# LLM_ENABLED=true
# LLM_TEMPERATURE=0.1
# CACHE_ENABLED=true
